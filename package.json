{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:tui": "turbo run dev --ui=tui",
    "dev:web": "turbo run dev --filter @atlas/web",
    "dev:api": "turbo run dev --filter @atlas/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint-staged": "lint-staged",
    "typecheck": "turbo typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,css,json,yaml,yml}": "prettier --write"
  }
}
